{
  "name": "festival",
  "description": "Festival",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stephenwade/festival.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky; prisma generate",
    "dev": "nodemon --ext ts,env --exec node --env-file=.env server/index.ts",
    "build": "remix vite:build",
    "start": "NODE_ENV=production node server/index.ts",
    "lint:dpdm": "dpdm 'app/routes/*' server/index.ts --no-tree --no-warning --exit-code circular:1",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:knip": "knip",
    "lint:prettier": "prettier . --check --ignore-path .gitignore --log-level warn",
    "lint:stylelint": "stylelint \"**/*.css\" --ignore-path .gitignore --max-warnings 0",
    "lint:tsc": "tsc --build",
    "lint": "npm-run-all lint:*",
    "format:eslint": "eslint . --max-warnings=0 --fix",
    "format:knip": "knip --fix",
    "format:prettier": "prettier . --write --ignore-path .gitignore --log-level warn",
    "format:stylelint": "stylelint \"**/*.css\" --fix --ignore-path .gitignore --max-warnings 0",
    "format": "npm-run-all format:*",
    "test": "playwright test",
    "test-ct": "playwright test -c playwright-ct.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1023.0",
    "@aws-sdk/s3-request-presigner": "3.1023.0",
    "@clerk/remix": "4.13.43",
    "@prisma/client": "6.19.3",
    "@remix-run/express": "2.17.4",
    "@remix-run/node": "2.17.4",
    "@remix-run/react": "2.17.4",
    "@remix-validated-form/with-zod": "2.0.7",
    "@types/express": "4.17.25",
    "express": "4.22.1",
    "nanoid": "5.1.7",
    "node-cache": "5.1.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-helmet-async": "3.0.0",
    "react-timezone-select": "3.3.3",
    "react-toastify": "11.0.5",
    "remix-utils": "7.7.0",
    "remix-validated-form": "5.1.5",
    "standardized-audio-context": "25.3.77",
    "temporal-polyfill": "0.3.2",
    "use-local-storage-state": "19.5.0",
    "usehooks-ts": "3.1.1",
    "zod": "3.25.76",
    "zod-form-data": "2.0.8"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.4",
    "@eslint/js": "9.39.4",
    "@playwright/experimental-ct-react": "1.59.1",
    "@playwright/test": "1.59.1",
    "@remix-run/dev": "2.17.4",
    "@remix-run/fs-routes": "2.17.4",
    "@remix-run/route-config": "2.17.4",
    "@remix-run/testing": "2.17.4",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/node": "24.12.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "dpdm": "4.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-playwright": "2.7.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "knip": "6.3.0",
    "lint-staged": "16.4.0",
    "nodemon": "3.1.14",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "prisma": "6.19.3",
    "stylelint": "17.6.0",
    "stylelint-config-hudochenkov": "13.0.2",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "svgo": "4.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "use-deep-compare": "1.3.0",
    "vite": "8.0.7"
  },
  "lint-staged": {
    "*.css": "stylelint --fix",
    "*.prisma": "prisma format --schema",
    "*.svg": "svgo",
    "*": "prettier --ignore-unknown --write --ignore-path .gitignore"
  }
}
