{
  "name": "festival",
  "description": "Festival",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stephenwade/festival.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky; prisma generate",
    "dev": "nodemon --ext ts,env --exec node --env-file=.env server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.ts",
    "lint:dpdm": "dpdm app/main.tsx server/index.ts --no-tree --no-warning --exit-code circular:1",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:knip": "knip",
    "lint:prettier": "prettier . --check --ignore-path .gitignore --log-level warn",
    "lint:stylelint": "stylelint \"**/*.css\" --ignore-path .gitignore --max-warnings 0",
    "lint:tsc": "tsc --build",
    "lint": "npm-run-all lint:*",
    "format:eslint": "eslint . --max-warnings=0 --fix",
    "format:knip": "knip --fix",
    "format:prettier": "prettier . --write --ignore-path .gitignore --log-level warn",
    "format:stylelint": "stylelint \"**/*.css\" --fix --ignore-path .gitignore --max-warnings 0",
    "format": "npm-run-all format:*",
    "test": "playwright test",
    "pretest-ct": "rm -rf playwright/ct-tests/.cache",
    "test-ct": "playwright test -c playwright-ct.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1072.0",
    "@aws-sdk/s3-request-presigner": "3.1072.0",
    "@clerk/backend": "3.8.4",
    "@clerk/express": "2.1.32",
    "@clerk/react": "6.11.1",
    "@mantine/hooks": "9.4.1",
    "@prisma/client": "6.19.3",
    "@rvf/core": "8.1.1",
    "@rvf/react": "8.1.2",
    "@tanstack/react-query": "5.101.2",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "@types/express": "5.0.6",
    "express": "5.2.1",
    "nanoid": "5.1.16",
    "node-cache": "5.1.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "react-timezone-select": "3.3.3",
    "react-toastify": "11.1.0",
    "standardized-audio-context": "25.3.77",
    "temporal-polyfill": "0.3.2",
    "vite-express": "0.22.1",
    "zod": "4.4.3",
    "zod-form-data": "3.0.2"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint-react/eslint-plugin": "5.9.5",
    "@eslint/js": "10.0.1",
    "@playwright/experimental-ct-core": "1.61.1",
    "@playwright/experimental-ct-react": "1.61.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "dpdm": "4.2.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-jsx-a11y-x": "0.2.0",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "69.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "knip": "6.22.0",
    "lint-staged": "17.0.8",
    "msw-trpc": "2.0.1",
    "nodemon": "3.1.14",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.1",
    "prisma": "6.19.3",
    "stylelint": "17.14.0",
    "stylelint-config-hudochenkov": "13.0.2",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "svgo": "4.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0"
  }
}
