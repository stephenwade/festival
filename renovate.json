{
  "enabled": true,

  "extends": ["config:best-practices", "config:js-app"],

  "timezone": "America/New_York",

  "lockFileMaintenance": {
    "enabled": true,
    "extends": ["schedule:weekly"],
    "automerge": true
  },

  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": "!/^[~^]?0/",
      "automerge": true
    },
    {
      "description": "Schedule aws-sdk updates on Tuesday mornings",
      "matchPackageNames": ["@aws-sdk/*"],
      "schedule": ["* 0-3 * * 1"]
    },
    {
      "groupName": "Stylelint",
      "matchPackageNames": ["stylelint", "stylelint-*"]
    }
  ]
}
