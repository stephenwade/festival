{
  "include": [
    "*.config.js",
    "*.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/utils/auth-route-guards"
  ],
  "exclude": ["build", "server/**/*.ts"],
  "compilerOptions": {
    "module": "esnext",
    "types": ["vite/client"],
    "jsx": "react-jsx",

    "allowJs": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,

    "noEmit": true,
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.client.tsbuildinfo"
  }
}
